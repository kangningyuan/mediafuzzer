# MediaFuzzer 环境变量配置
# 复制此文件为 .env 并填写实际值: cp .env.example .env

# ---- LLM API（必填）----
# 注意：配置项名为 LLM_API_KEY，但环境变量名为 OPENAI_API_KEY（兼容 OpenAI SDK）
OPENAI_API_KEY=
LLM_API_BASE=
LLM_MODEL_NAME=glm-5.1

# ---- LLVM / LibFuzzer ----
CLANG_PATH=/usr/bin/clang-18
LIBCLANG_RT_PATH=/usr/lib/llvm-18/lib/clang/18/lib/linux/
LIBFUZZER_TIMEOUT=300
LIBFUZZER_MAX_RUNS=100000

# ---- Qiling 模拟 ----
QL_ROOTFS_PATH=rootfs/arm64_android
QL_ARCH=arm64
QL_OS=linux
QL_VERBOSE=0
QL_TIMEOUT=5000

# ---- APK / SO 路径 ----
APK_INPUT_DIR=data/apks
SO_OUTPUT_DIR=data/extracted_so

# ---- LLM 高级 ----
LLM_MAX_RETRIES=3
LLM_RETRY_DELAY=1.0
LLM_TEMPERATURE=0.0

# ---- 覆盖率 / 内存安全 ----
COV_BITMAP_SIZE=65536
MEM_SAFETY_ENABLED=true
MEM_TAG_BITS=16

# ---- 输出 ----
OUTPUT_BASE_DIR=output
